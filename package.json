  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "cpu": [
    "x64",
    "arm64"
  ],
  "keywords": [
    "apps-in-toss",
    "toss",
    "mcp",
    "mcp-server",
    "mini-app",
    "cli"
  ],
  "author": "Viva Republica, Inc.",
  "license": "ISC",
  "publishConfig": {
    "access": "public"
